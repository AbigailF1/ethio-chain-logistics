# PostgreSQL
POSTGRES_DB=ethio_chain
POSTGRES_USER=ethio_user
POSTGRES_PASSWORD=ethio_pass
POSTGRES_PORT=5432

# API (backend/)
API_PORT=8080
GIN_MODE=debug
JWT_SECRET=dev-secret
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin123
# Local Postgres URL (host machine → Docker published port)
DATABASE_URL=postgres://ethio_user:ethio_pass@localhost:5432/ethio_chain?sslmode=disable
# When running the API inside Docker, use host `postgres` instead of `localhost`.
# POSTGRES_HOST=localhost

# Blockchain anchoring (free local Ethereum by default)
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=hardhat-local
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_PRIVATE_KEY=
ANCHOR_CONTRACT_ADDRESS=
BLOCK_EXPLORER_TX_BASE=
NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=
ANCHOR_WORKER_INTERVAL_SECONDS=5
ANCHOR_CONFIRM_TIMEOUT_SECONDS=60
